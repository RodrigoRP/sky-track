# ── Supabase ──────────────────────────────────────────────────────────────────
# Create a free project at https://supabase.com and copy these from:
#   Project Settings → API → Project URL / anon key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── Amadeus Flight Price API ────────────────────────────────────────────────
# Free sandbox at https://developers.amadeus.com → My Apps → Create API Key
# Set grant_type=client_credentials to get access tokens
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate a VAPID key pair:  npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:hello@your-domain.com

# ── Email fallback (Resend) ───────────────────────────────────────────────────
# Free tier at https://resend.com — needed for iOS Safari push fallback
RESEND_API_KEY=re_your_resend_key
